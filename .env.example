# ── Iron-IQ Local Development Environment
# Copy this file to .env.local and fill in values
# DO NOT commit .env.local to version control

# Token the frontend sends with every API call
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=replace-with-your-generated-hex-string

# Secret used to sign session tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-another-generated-hex-string

# Password clients use on the login screen
DEMO_PASSWORD=replace-with-your-demo-password

# Allowed CORS origin (set to your Vercel URL in production)
ALLOWED_ORIGIN=http://localhost:3000
